# Langchain-Chatchat 环境变量配置模板
# 复制此文件为 .env 并修改相应配置项
# 所有 ${VAR} 格式的引用都可以通过环境变量覆盖

# 数据根目录（必须）
CHATCHAT_ROOT=D:\Langchain-Chatchat-master\chatchat_data

# 运行环境: dev / staging / prod
CHATCHAT_ENV=dev

# 数据库连接 URI
# SQLite (开发用):
# SQLALCHEMY_DATABASE_URI=sqlite:///D:/Langchain-Chatchat-master/chatchat_data/data/knowledge_base/info.db
# PostgreSQL (生产用):
# SQLALCHEMY_DATABASE_URI=postgresql://user:password@localhost:5432/chatchat

# 百炼平台 API Key（对应 model_settings.yaml 中 ${OPENAI_API_KEY} 引用）
OPENAI_API_KEY=sk-your-key-here

# Langfuse 可观测性（可选）
# LANGFUSE_SECRET_KEY=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_HOST=
